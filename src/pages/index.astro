---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projectsData from "../../content/projects.json";
import pageData from "../../content/page.json";
import logosData from "../../content/logos.json";

const projects = projectsData.projects;
const page = pageData;
const logos = logosData.logos;
const teamMembers = page.teamMembers;
---

<Layout
  title="Digital rekvisita för film och TV"
  description="Interaktiv digital design och grafiska lösningar för TV och filmproduktioner. Vi skräddarsyr fiktiva gränssnitt för alla typer av skärmar och enheter."
>
  <main>
    <!-- Nav -->
    <nav id="start">
      <div class="nav-inner">
        <a href="#" class="nav-logo">
          <img
            src="/images/68dc26a8c975bbe237511944_digitalrekvisita_logo.svg"
            alt="Digitalrekvisita"
          />
        </a>
        <button class="nav-toggle" aria-label="Meny" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="nav-links">
          <a href="#om">Kontakt</a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <header class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-left">
            <h1>{page.heroTitle}</h1>
          </div>
          <div class="hero-right">
            <p set:html={page.heroBody} />
          </div>
        </div>
      </div>
    </header>

    <!-- Projects -->
    <section class="projects">
      <div class="container">
        <div class="projects-grid">
          {projects.map((project) => (
            <ProjectCard
              title={project.title}
              meta={project.meta}
              description={project.description}
              image={`/images/${project.image}`}
              blurThumbnail={project.blurThumbnail}
              videoMp4={project.videoMp4 ? `/videos/${project.videoMp4}` : undefined}
              videoWebm={project.videoWebm ? `/videos/${project.videoWebm}` : undefined}
              videoPoster={project.videoPoster ? `/images/${project.videoPoster}` : undefined}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="about" id="om">
      <div class="container">
        <div class="about-grid">
          <div class="about-left">
            <h2>{page.aboutTitle}</h2>
            <p>{page.aboutBody}</p>
            {page.instagramHandle && (
              <p class="instagram-note">
                Följ oss gärna på Instagram: <a
                  href={`https://www.instagram.com/${page.instagramHandle.replace('@', '')}`}
                  target="_blank"
                  rel="noopener">{page.instagramHandle}</a>
              </p>
            )}
          </div>
          <div class="about-right">
            <div class="team-photos">
              {teamMembers.map((member) => (
                <div class="team-member">
                  <img
                    src={`/images/${member.image}`}
                    alt={member.name}
                    loading="lazy"
                  />
                  <div class="member-info">
                    <strong>{member.name}</strong>
                    <span>{member.email}</span>
                    <a href={`tel:${member.phoneHref}`}>{member.phone}</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Logos -->
    <section class="logos" id="kunder">
      <div class="container">
        <div class="logos-grid">
          {logos.map((logo) => (
            <img
              src={`/images/${logo.image}`}
              alt={logo.name}
              class="logo-img"
              loading="lazy"
              style={logo.height ? `height:${logo.height}px` : undefined}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="container footer-inner">
        <img
          src="/images/68dc26a8c975bbe237511944_digitalrekvisita_logo.svg"
          alt="Digitalrekvisita"
          class="footer-logo"
        />
        <a href="#" class="to-top" id="to-top">Till toppen</a>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* Container */
  .container {
    padding: 0 76px;
  }

  /* Nav */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    transition: background 0.3s;
  }

  nav.scrolled {
    background: rgba(22, 22, 22, 0.95);
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    padding: 0 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo img {
    height: 29px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #05ff00;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 5px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    transition: all 0.3s;
  }

  /* Hero */
  .hero {
    padding: 17rem 0 13rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .hero-left h1 {
    font-size: 56px;
    font-weight: 400;
    line-height: 1.2;
    color: #05ff00;
  }

  .hero-right p {
    font-size: 20.8px;
    font-weight: 300;
    color: #fff;
    line-height: 36.8px;
    padding-top: 1rem;
  }

  .hero-right strong {
    color: #05ff00;
    font-weight: 300;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Projects */
  .projects {
    padding: 0 0 13rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  /* Services */
  .services {
    padding: 6rem 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
  }

  .services-left h2 {
    font-size: 56px;
    font-weight: 400;
    color: #05ff00;
    position: sticky;
    top: 6rem;
  }

  .services-right {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .service-group {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .service-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
  }

  .service-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .service-group h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .service-group ul {
    list-style: disc;
    padding-left: 1.2rem;
  }

  .service-group li {
    font-size: 16px;
    font-weight: 300;
    color: #f4f4f4;
    margin-bottom: 0.35rem;
  }

  .service-note {
    font-size: 16px;
    font-weight: 300;
    color: #f4f4f4;
    margin-bottom: 0.75rem;
  }

  .service-note a {
    color: #05ff00;
    text-decoration: underline;
  }

  /* Logos */
  .logos {
    padding: 128px 180px 192px;
  }

  .logos-grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 60px 72px;
  }

  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
    transition: opacity 0.3s;
  }

  /* Balance visual weight of logos */
  .logo-img.logo-tall {
    height: 64px;
  }

  .logo-img.logo-wide {
    height: 36px;
  }

  .logo-img:hover {
    opacity: 0.7;
  }

  /* About */
  .about {
    padding: 0 0 160px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
  }

  .about-left h2 {
    font-size: 56px;
    font-weight: 400;
    color: #05ff00;
    margin-bottom: 1.5rem;
  }

  .about-left p {
    font-size: 20.8px;
    font-weight: 300;
    color: #fff;
    line-height: 36.8px;
    margin-bottom: 1rem;
  }

  .instagram-note a {
    color: #05ff00;
  }

  .about-right {
    display: flex;
    flex-direction: column;
  }

  .team-photos {
    display: flex;
    flex-direction: row;
    gap: 11px;
  }

  .team-member {
    flex: 1;
  }

  .team-member img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    margin-bottom: 1rem;
  }

  .member-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 20.8px;
    font-weight: 300;
    line-height: 36.8px;
  }

  .member-info strong {
    font-weight: 500;
  }

  .member-info span,
  .member-info a {
    font-weight: 300;
    color: #fff;
  }

  .member-info a:hover {
    color: #05ff00;
  }

  /* Footer */
  footer {
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    height: 20px;
    width: auto;
    opacity: 0.6;
  }

  .to-top {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s;
  }

  .to-top:hover {
    color: #05ff00;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(22, 22, 22, 0.98);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      z-index: 99;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links a {
      font-size: 1.5rem;
    }

    .nav-toggle {
      display: flex;
      z-index: 101;
    }

    .nav-toggle.open span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .nav-toggle.open span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle.open span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }

    .hero-grid,
    .services-grid,
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero {
      padding: 7rem 0 4rem;
    }

    .hero-left h1 {
      font-size: 32px;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Nav scroll effect
  const nav = document.querySelector("nav");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add("scrolled");
    } else {
      nav?.classList.remove("scrolled");
    }
  });

  // Mobile menu toggle
  const toggle = document.querySelector(".nav-toggle");
  const links = document.querySelector(".nav-links");
  toggle?.addEventListener("click", () => {
    toggle.classList.toggle("open");
    toggle.setAttribute(
      "aria-expanded",
      toggle.classList.contains("open").toString()
    );
    links?.classList.toggle("open");
  });

  // Close menu on link click
  links?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      toggle?.classList.remove("open");
      links?.classList.remove("open");
    });
  });

  // Smooth scroll to top
  document.getElementById("to-top")?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>

---
interface Props {
  title: string;
  meta: string;
  description: string;
  image: string;
  blurThumbnail?: boolean;
  videoMp4?: string;
  videoWebm?: string;
  videoPoster?: string;
}

const { title, meta, description, image, blurThumbnail, videoMp4, videoWebm, videoPoster } = Astro.props;
const hasVideo = !!videoMp4;
---

<div class="project-card" data-has-video={hasVideo ? "true" : undefined}>
  <div class="card-media">
    <img
      src={image}
      alt={title}
      loading="lazy"
      class:list={["card-image", { "card-image-blur": blurThumbnail }]}
    />
    {hasVideo && (
      <video
        class="card-video"
        muted
        loop
        playsinline
        preload="none"
        poster={videoPoster || undefined}
      >
        <source src={videoMp4} type="video/mp4" />
        {videoWebm && <source src={videoWebm} type="video/webm" />}
      </video>
    )}
    <div class="card-overlay"></div>
  </div>
  <div class="card-text">
    <div class="card-title-row">
      <span class="card-name">{title} </span>
      <span class="card-meta">{meta}</span>
    </div>
    <p class="card-description">{description}</p>
  </div>
</div>

<style>
  .project-card {
    position: relative;
    cursor: pointer;
    overflow: hidden;
  }

  .card-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .card-image-blur {
    filter: blur(20px);
    transform: scale(1.05);
  }

  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.3s ease;
  }

  .project-card:hover .card-overlay {
    background: rgba(0, 0, 0, 0.15);
  }

  .project-card:hover .card-video,
  .project-card.mobile-playing .card-video {
    opacity: 1;
  }

  .project-card:hover .card-image,
  .project-card.mobile-playing .card-image {
    opacity: 0;
  }

  .project-card:not([data-has-video]):hover .card-image {
    opacity: 1;
    transform: scale(1.03);
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .card-text {
    padding: 1rem 0.25rem;
  }

  .card-title-row {
    margin-bottom: 0.25rem;
  }

  .card-name {
    font-size: 16px;
    font-weight: 500;
    color: #05ff00;
  }

  .card-meta {
    font-size: 16px;
    font-weight: 100;
    color: #fff;
  }

  .card-description {
    font-size: 16px;
    font-weight: 300;
    color: #f4f4f4;
    line-height: 1.5;
  }
</style>

<script>
  const isMobile = () => window.matchMedia('(hover: none)').matches;

  // IntersectionObserver for mobile scroll-to-play
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!isMobile()) return;
      const card = entry.target as HTMLElement;
      const video = card.querySelector('video') as HTMLVideoElement | null;
      if (!video) return;
      if (entry.isIntersecting) {
        video.play().catch(() => {});
        card.classList.add('mobile-playing');
      } else {
        video.pause();
        card.classList.remove('mobile-playing');
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.project-card[data-has-video]').forEach((card) => {
    const video = card.querySelector('video') as HTMLVideoElement | null;
    if (!video) return;

    // Desktop: hover to play
    card.addEventListener('mouseenter', () => {
      if (isMobile()) return;
      video.currentTime = 0;
      video.play().catch(() => {});
    });

    card.addEventListener('mouseleave', () => {
      if (isMobile()) return;
      video.pause();
    });

    // Register for scroll-based play on mobile
    observer.observe(card);

    // Mobile: tap to play/pause (fallback)
    card.addEventListener('click', () => {
      if (!isMobile()) return;
      if (video.paused) {
        video.currentTime = 0;
        video.play().catch(() => {});
        (card as HTMLElement).classList.add('playing');
      } else {
        video.pause();
        (card as HTMLElement).classList.remove('playing');
      }
    });
  });
</script>

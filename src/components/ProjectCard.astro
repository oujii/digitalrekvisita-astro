---
interface Props {
  title: string;
  meta: string;
  description: string;
  image: string;
  videoMp4?: string;
  videoWebm?: string;
  videoPoster?: string;
}

const { title, meta, description, image, videoMp4, videoWebm, videoPoster } = Astro.props;
const hasVideo = !!videoMp4;
---

<div class="project-card" data-has-video={hasVideo ? "true" : undefined}>
  <div class="card-media">
    <img
      src={`/images/${image}`}
      alt={title}
      loading="lazy"
      class="card-image"
    />
    {hasVideo && (
      <video
        class="card-video"
        muted
        loop
        playsinline
        preload="none"
        poster={videoPoster ? `/images/${videoPoster}` : undefined}
      >
        <source src={`/videos/${videoMp4}`} type="video/mp4" />
        {videoWebm && <source src={`/videos/${videoWebm}`} type="video/webm" />}
      </video>
    )}
    <div class="card-overlay"></div>
  </div>
  <div class="card-text">
    <div class="card-title-row">
      <span class="card-name">{title} </span>
      <span class="card-meta">{meta}</span>
    </div>
    <p class="card-description">{description}</p>
  </div>
</div>

<style>
  .project-card {
    position: relative;
    cursor: pointer;
    overflow: hidden;
    border-radius: 4px;
    background: #111;
  }

  .card-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.3s ease;
  }

  .project-card:hover .card-overlay {
    background: rgba(0, 0, 0, 0.15);
  }

  .project-card:hover .card-video {
    opacity: 1;
  }

  .project-card:hover .card-image {
    opacity: 0;
  }

  .project-card:not([data-has-video]):hover .card-image {
    opacity: 1;
    transform: scale(1.03);
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .card-text {
    padding: 1rem 0.25rem;
  }

  .card-title-row {
    margin-bottom: 0.25rem;
  }

  .card-name {
    font-family: "Inconsolata", monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
  }

  .card-meta {
    font-family: "Inconsolata", monospace;
    font-size: 0.9rem;
    font-weight: 400;
    color: #05ff00;
  }

  .card-description {
    font-family: "Roboto", sans-serif;
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
  }
</style>

<script>
  document.querySelectorAll('.project-card[data-has-video]').forEach((card) => {
    const video = card.querySelector('video') as HTMLVideoElement | null;
    if (!video) return;

    card.addEventListener('mouseenter', () => {
      video.currentTime = 0;
      video.play().catch(() => {});
    });

    card.addEventListener('mouseleave', () => {
      video.pause();
    });

    // Mobile: tap to play/pause
    card.addEventListener('click', () => {
      if (video.paused) {
        video.currentTime = 0;
        video.play().catch(() => {});
        (card as HTMLElement).classList.add('playing');
      } else {
        video.pause();
        (card as HTMLElement).classList.remove('playing');
      }
    });
  });
</script>
